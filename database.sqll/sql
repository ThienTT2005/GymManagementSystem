-- Tạo Database mới
DROP DATABASE IF EXISTS GymManagement;
CREATE DATABASE GymManagement CHARACTER SET utf8mb4;
USE GymManagement;

-- 1. Roles
CREATE TABLE roles (
    role_id INT PRIMARY KEY AUTO_INCREMENT,
    role_name VARCHAR(50) NOT NULL
);

-- 2. Clubs
CREATE TABLE clubs (
    club_id INT PRIMARY KEY AUTO_INCREMENT,
    club_name VARCHAR(100) NOT NULL,
    address TEXT,
    phone VARCHAR(20)
);

-- 3. Users
CREATE TABLE users (
    user_id INT PRIMARY KEY AUTO_INCREMENT,
    username VARCHAR(50) UNIQUE NOT NULL,
    password VARCHAR(255) NOT NULL,
    full_name VARCHAR(100),
    role_id INT,
    status VARCHAR(20) DEFAULT 'Active',
    FOREIGN KEY (role_id) REFERENCES roles(role_id)
);

-- 4. Trainers
CREATE TABLE trainers (
    trainer_id INT PRIMARY KEY AUTO_INCREMENT,
    trainer_name VARCHAR(100),
    club_id INT,
    specialty VARCHAR(100),
    FOREIGN KEY (club_id) REFERENCES clubs(club_id)
);

-- 5. Services
CREATE TABLE services (
    service_id INT PRIMARY KEY AUTO_INCREMENT,
    service_name VARCHAR(100),
    description TEXT
);

-- 6. Packages
CREATE TABLE packages (
    package_id INT PRIMARY KEY AUTO_INCREMENT,
    package_name VARCHAR(100),
    price DECIMAL(10, 2),
    duration_month INT
);

-- 7. Schedules
CREATE TABLE schedules (
    schedule_id INT PRIMARY KEY AUTO_INCREMENT,
    service_id INT,
    trainer_id INT,
    club_id INT,
    day_of_week VARCHAR(20),
    start_time TIME,
    FOREIGN KEY (service_id) REFERENCES services(service_id),
    FOREIGN KEY (trainer_id) REFERENCES trainers(trainer_id),
    FOREIGN KEY (club_id) REFERENCES clubs(club_id)
);

-- 8. Memberships
CREATE TABLE memberships (
    membership_id INT PRIMARY KEY AUTO_INCREMENT,
    user_id INT,
    package_id INT,
    start_date DATE,
    end_date DATE,
    FOREIGN KEY (user_id) REFERENCES users(user_id),
    FOREIGN KEY (package_id) REFERENCES packages(package_id)
);

-- 9. Payments
CREATE TABLE payments (
    payment_id INT PRIMARY KEY AUTO_INCREMENT,
    membership_id INT,
    amount DECIMAL(10, 2),
    status VARCHAR(20) DEFAULT 'Pending',
    FOREIGN KEY (membership_id) REFERENCES memberships(membership_id)
);

-- 10. Class_Registrations
CREATE TABLE class_registrations (
    registration_id INT PRIMARY KEY AUTO_INCREMENT,
    user_id INT,
    schedule_id INT,
    FOREIGN KEY (user_id) REFERENCES users(user_id),
    FOREIGN KEY (schedule_id) REFERENCES schedules(schedule_id)
);

-- 11. Trial_Registrations
CREATE TABLE trial_registrations (
    trial_id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100), phone VARCHAR(20), club_id INT,
    FOREIGN KEY (club_id) REFERENCES clubs(club_id)
);

-- 12. News
CREATE TABLE news (news_id INT PRIMARY KEY AUTO_INCREMENT, title VARCHAR(255), content TEXT);

-- 13. Contacts
CREATE TABLE contacts (contact_id INT PRIMARY KEY AUTO_INCREMENT, name VARCHAR(100), message TEXT);